---
import BriefingCard from "~/components/BriefingCard.astro";
import HeroLatest from "~/components/HeroLatest.astro";
import HighlightsList from "~/components/HighlightsList.astro";
import Masthead from "~/components/Masthead.astro";
import PlaceholderCard from "~/components/PlaceholderCard.astro";
import { BRIEFINGS } from "~/config/briefings";
import type { LoadedBriefing } from "~/lib/highlights";
import { mergeAndSortItems } from "~/lib/highlights";
import { loadAll, pickLatest, type FailedBriefing } from "~/lib/hub";
import BaseLayout from "~/layouts/BaseLayout.astro";

const { loaded, failed } = await loadAll(BRIEFINGS);
const hero = pickLatest(loaded);
const highlights = mergeAndSortItems(loaded);
const now = new Date();

const KST_OFFSET_MS = 9 * 60 * 60 * 1000;

function toSeoulDate(value: Date): Date {
  return new Date(value.getTime() + KST_OFFSET_MS);
}

function formatSeoulDate(value: Date): string {
  const seoul = toSeoulDate(value);
  const year = seoul.getUTCFullYear();
  const month = String(seoul.getUTCMonth() + 1).padStart(2, "0");
  const day = String(seoul.getUTCDate()).padStart(2, "0");
  return `${year}-${month}-${day}`;
}

function isoWeekInSeoul(value: Date): number {
  const seoul = toSeoulDate(value);
  const date = new Date(Date.UTC(seoul.getUTCFullYear(), seoul.getUTCMonth(), seoul.getUTCDate()));
  const dayNumber = date.getUTCDay() || 7;
  date.setUTCDate(date.getUTCDate() + 4 - dayNumber);
  const yearStart = new Date(Date.UTC(date.getUTCFullYear(), 0, 1));
  return Math.ceil(((date.getTime() - yearStart.getTime()) / 86_400_000 + 1) / 7);
}

type CardSlot =
  | { kind: "loaded"; loaded: LoadedBriefing }
  | { kind: "failed"; failed: FailedBriefing };

const cardSlots = BRIEFINGS.map((config): CardSlot | null => {
  const loadedBriefing = loaded.find((entry) => entry.config.slug === config.slug);
  if (loadedBriefing) {
    return { kind: "loaded", loaded: loadedBriefing };
  }

  const failedBriefing = failed.find((entry) => entry.config.slug === config.slug);
  if (failedBriefing) {
    return { kind: "failed", failed: failedBriefing };
  }

  return null;
}).filter((slot): slot is CardSlot => slot !== null);
---
<BaseLayout title="Briefing Hub">
  <div class="container">
    <Masthead dateLabel={formatSeoulDate(now)} weekNumber={isoWeekInSeoul(now)} />

    {hero && <HeroLatest highlight={hero} />}

    <h2 class="section-h">Briefings</h2>
    <div class="grid">
      {cardSlots.map((slot) =>
        slot.kind === "loaded" ? (
          <BriefingCard loaded={slot.loaded} />
        ) : (
          <PlaceholderCard failed={slot.failed} />
        )
      )}
    </div>

    {highlights.length > 0 && <HighlightsList items={highlights} />}
  </div>
</BaseLayout>
